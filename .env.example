# Database: для разработки используйте SQLite (по умолчанию ./rental.db)
# Для продакшена используйте PostgreSQL (требует psycopg2-binary из requirements-prod.txt)
# SQLite: DATABASE_URL=sqlite:///./rental.db
# PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/rental_db
DATABASE_URL=sqlite:///./rental.db

# SECRET_KEY обязателен. Сгенерировать: openssl rand -hex 32
# Никогда не коммитьте реальный ключ в git!
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
